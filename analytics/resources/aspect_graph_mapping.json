{
  "name": "graph_mapping",
  "type": "record",
  "annotations": {
    "displayName": "Graph Mapping Ruleset",
    "description": "Ruleset for BigQuery Agent Text-to-GQL mapping."
  },
  "recordFields": [
    {
      "name": "type",
      "type": "string",
      "index": 1,
      "annotations": {
        "displayName": "Mapping Type",
        "description": "e.g. Graph_Node, Graph_Edge, Graph_Path"
      },
      "constraints": {
        "required": true
      }
    },
    {
      "name": "label",
      "type": "string",
      "index": 2,
      "annotations": {
        "displayName": "Graph Label",
        "description": "Graph relation or node label"
      }
    },
    {
      "name": "pattern",
      "type": "string",
      "index": 3,
      "annotations": {
        "displayName": "Graph Path Pattern",
        "description": "Cypher-like graph path traversal pattern query"
      }
    },
    {
      "name": "target_node",
      "type": "string",
      "index": 4,
      "annotations": {
        "displayName": "Target Node Label",
        "description": "Target graph node class"
      }
    },
    {
      "name": "target_edge",
      "type": "string",
      "index": 5,
      "annotations": {
        "displayName": "Target Edge Label",
        "description": "Target graph edge relationship label"
      }
    },
    {
      "name": "table",
      "type": "string",
      "index": 6,
      "annotations": {
        "displayName": "Associated Table",
        "description": "Associated BQ table for the mapping"
      }
    }
  ]
}
